---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";
import "./blog.css";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);
---

<Base
  title="Blog | Dunky"
  description="Dunky blog: DX tools that unlock powerful UIs."
>
  <main class="blog-page">
    <h1 class="blog-title">Blog</h1>
    {
      posts.length === 0 ? (
        <p class="blog-empty">No posts yet. Check back soon.</p>
      ) : (
        <ul class="blog-list">
          {posts.map((post) => (
            <li class="blog-item">
              <a class="blog-link" href={`/blog/${post.id}`}>
                <span class="blog-item-title">{post.data.title}</span>
                <span class="blog-item-date">
                  {post.data.date.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </span>
                <span class="blog-item-desc">{post.data.description}</span>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Base>
